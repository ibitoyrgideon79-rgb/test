{
  "redirects": [
    {
      "source": "/",
      "destination": "/SNITIS",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/SNITIS/_next/static/:path*",
      "destination": "https://snitis.vercel.app/SNITIS/_next/static/:path*"
    },
    {
      "source": "/_next/static/:path*",
      "destination": "https://snitis.vercel.app/SNITIS/_next/static/:path*"
    },
    {
      "source": "/SNITIS/:path*",
      "destination": "https://snitis.vercel.app/SNITIS/:path*"
    },
    {
      "source": "/:path*",
      "destination": "https://snitis.vercel.app/SNITIS/:path*"
    }
  ]
}
