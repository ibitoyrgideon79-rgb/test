{
  "redirects": [
    {
      "source": "/",
      "destination": "/SNITIS",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/FMYDHUB",
      "destination": "https://fmydfeedb.vercel.app"
    },
    {
      "source": "/FMYDHUB/(.*)",
      "destination": "https://fmydfeedb.vercel.app/$1"
    },
    {
      "source": "/FMYDHUB/_next/:path*",
      "destination": "https://fmydfeedb.vercel.app/_next/:path*"
    },
    {
      "source": "/SNITIS",
      "destination": "https://snitis.vercel.app"
    },
    {
      "source": "/SNITIS/(.*)",
      "destination": "https://snitis.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://snitis.vercel.app/$1"
    }
  ]
}
